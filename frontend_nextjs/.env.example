# Example environment configuration for the Next.js frontend.
# Copy this file to `.env` and fill in values appropriate for your environment.
#
# SECURITY NOTE:
# - Do NOT commit `.env` files.
# - Any variable prefixed with NEXT_PUBLIC_ is exposed to the browser bundle.
#   Never put secrets (passwords, private keys, DB credentials) in NEXT_PUBLIC_* variables.

# Base URL of the backend API (public)
NEXT_PUBLIC_API_BASE=http://localhost:3001
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# URL where this frontend is served (public)
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# WebSocket URL for real-time endpoints (public)
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws

# Runtime / build flags (public)
NEXT_PUBLIC_NODE_ENV=development
NEXT_PUBLIC_NEXT_TELEMETRY_DISABLED=1
NEXT_PUBLIC_ENABLE_SOURCE_MAPS=true
NEXT_PUBLIC_PORT=3000
NEXT_PUBLIC_TRUST_PROXY=false
NEXT_PUBLIC_LOG_LEVEL=info
NEXT_PUBLIC_HEALTHCHECK_PATH=/healthz
NEXT_PUBLIC_FEATURE_FLAGS={}
NEXT_PUBLIC_EXPERIMENTS_ENABLED=false

# Database-related values should NOT be used on the frontend.
# If you see your application requiring these from the client,
# refactor to move DB access to a backend-only service.
# (intentionally omitted)
